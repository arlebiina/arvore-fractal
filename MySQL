CREATE OR REPLACE VIEW v_media_por_categoria AS
SELECT
    c.nome_categoria,
    AVG(p.preco) AS media_preco_categoria
FROM categorias c
JOIN produtos p ON c.id_categoria = p.id_categoria
GROUP BY c.nome_categoria;

CREATE OR REPLACE VIEW v_vendas_por_produto AS
SELECT 
    p.id_produto,
    p.nome_produto,
    p.id_categoria,
    SUM(ip.quantidade) AS total_vendido
FROM produtos p
JOIN itens_pedido ip ON p.id_produto = ip.id_produto
GROUP BY p.id_produto, p.nome_produto, p.id_categoria;

CREATE OR REPLACE VIEW v_analise_estrategica AS
SELECT 
    m.nome_categoria,
    v.nome_produto,
    v.total_vendido,
    m.media_preco_categoria
FROM v_vendas_por_produto v
JOIN v_media_por_categoria m ON v.id_categoria = (SELECT id_categoria FROM categorias WHERE nome_categoria = m.nome_categoria)
WHERE v.total_vendido > 1;

SELECT * FROM v_analise_estrategica;

CREATE OR REPLACE VIEW v_vendas_por_produto AS
SELECT 
    p.id_produto,
    p.nome_produto,
    p.id_categoria,
    SUM(ip.quantidade) AS total_vendido
FROM produtos p
JOIN itens_pedido ip ON p.id_produto = ip.id_produto
GROUP BY p.id_produto, p.nome_produto, p.id_categoria;
