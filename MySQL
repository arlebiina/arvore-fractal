-- Criar tabela clientes
CREATE TABLE clientes (
    id_cliente INT PRIMARY KEY,           -- Identificador único do cliente
    nome VARCHAR(100) NOT NULL,           -- Nome do cliente
    cpf VARCHAR(14) UNIQUE NOT NULL,      -- CPF de cada cliente (sendo único)
    email VARCHAR(100),                   -- Email do cliente
    telefone VARCHAR(15),                 -- Telefone
    data_nascimento DATE                  -- Data de nascimento do cliente
);

-- Criar tabela fornecedores
CREATE TABLE fornecedores (              
  Id_fornecedor INT PRIMARY KEY,         -- Indentificador de fornecedores
  nome_social VARCHAR (100) NOT NULL,    
  cnpj VARCHAR (18) UNIQUE NOT NULL,
  telefone VARCHAR(15),
  endereco INT NOT NULL
);

-- Criar tabela categorias
CREATE TABLE categorias (
    id_categoria INT PRIMARY KEY,         -- Identificador da categoria
    nome_categoria VARCHAR(100) NOT NULL  
);

-- Tabela produtos
CREATE TABLE produtos (
    id_produto INT PRIMARY KEY,
    nome_produto VARCHAR(100) NOT NULL,
    descricao TINYTEXT,
    preco DECIMAL(8,2) NOT NULL,
    id_categoria INT NOT NULL,
    id_fornecedor INT NOT NULL,

    CONSTRAINT fk_categoria
    FOREIGN KEY (id_categoria)
    REFERENCES categorias(id_categoria),

    CONSTRAINT fk_fornecedor
    FOREIGN KEY (id_fornecedor)
    REFERENCES fornecedores(id_fornecedor)
);

-- Tabela Estoque
CREATE TABLE estoque (
    id_estoque INT PRIMARY KEY,           -- Identificador do estoque
    id_produto INT,                      
    quantidade INT NOT NULL,  

    CONSTRAINT fk_estoque
    FOREIGN KEY (id_produto)
    REFERENCES produtos(id_produto)
);

-- tabela pedidos
CREATE TABLE pedidos (
   id_pedido INT PRIMARY KEY,
   id_cliente INT,
   data_pedido DATE,
   status_pedido ENUM('Pendente', 'Pago', 'Enviado', 'Entregue', 'Cancelado') NOT NULL DEFAULT 'Pendente',
   valor_total DECIMAL (10,2) NOT NULL,
   
    CONSTRAINT fk_pedido
    FOREIGN KEY (id_cliente)
    REFERENCES clientes(id_cliente)
);

-- Criar tabela intens_pedido
CREATE TABLE itens_pedido (
    id_pedido INT NOT NULL,
    id_produto INT NOT NULL,
    quantidade INT NOT NULL,
    preco_unitario DECIMAL(10,2),

    PRIMARY KEY (id_pedido, id_produto),

 -- Criação da chave estrangeira
    CONSTRAINT fk_item_pedido -- apelido
    FOREIGN KEY (id_pedido)
    REFERENCES pedidos(id_pedido),

    CONSTRAINT fk_item_produto
    FOREIGN KEY (id_produto)
    REFERENCES produtos(id_produto)
);

